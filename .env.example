# Back-main/.env.example
# Copy to .env and fill values for local development or production.

# Use local MongoDB during development? Set to true to prefer MONGODB_LOCAL_URI.
USE_LOCAL_DB=true

# Local MongoDB URI (example)
MONGODB_LOCAL_URI=mongodb://localhost:27017/authplatform

# MongoDB Atlas URI (example - keep this out of version control)
# MONGODB_URI=mongodb+srv://user:password@cluster0.example.mongodb.net/authplatform?retryWrites=true&w=majority

# JWT secret - keep secret in production
JWT_SECRET=your_jwt_secret_here

# CORS origins (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Server port
PORT=5000
