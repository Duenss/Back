{
  "AWSEBDockerrunVersion": 2,
  "containerDefinitions": [
    {
      "name": "authplatform-backend",
      "image": "",
      "essential": true,
      "memoryReservation": 256,
      "portMappings": [
        {
          "hostPort": 8081,
          "containerPort": 8081,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" }
      ],
      "mountPoints": [],
      "command": ["npm", "start"],
      "workingDirectory": "/app"
    }
  ]
}
